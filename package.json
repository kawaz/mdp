{
  "name": "@kawaz/mdp",
  "version": "0.1.5",
  "description": "Terminal Markdown Preview CLI powered by MoonBit",
  "bin": {
    "mdp": "./bin/mdp.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "moon build --target js --release && V=$(node -p \"require('./package.json').version\") && bun build _build/js/release/build/src/src.js --outfile=dist/mdp.js --minify --target=node --define \"__MDP_VERSION__='$V'\"",
    "test": "moon test --target js",
    "version": "node -e \"const p=require('./package.json'),fs=require('fs'),m=JSON.parse(fs.readFileSync('moon.mod.json','utf-8'));m.version=p.version;fs.writeFileSync('moon.mod.json',JSON.stringify(m,null,2)+'\\n')\" && git add moon.mod.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "markdown",
    "terminal",
    "cli",
    "tui",
    "preview",
    "moonbit",
    "ansi"
  ],
  "author": "kawaz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kawaz/mdp.git"
  },
  "bugs": {
    "url": "https://github.com/kawaz/mdp/issues"
  },
  "homepage": "https://github.com/kawaz/mdp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  }
}
